# ============================================================
# Rails-8-API-Authentication – environment variable reference
# Copy this file to .env and fill in values for local dev.
# Never commit .env to version control.
# ============================================================

# ── Rails core ───────────────────────────────────────────────
# Set to development | test | production
RAILS_ENV=development

# Log to STDOUT (required for Docker / Kamal log tailing)
RAILS_LOG_TO_STDOUT=true

# Port for local Puma. Thruster/Kamal ignores this in production.
PORT=4000

# Number of Puma threads per worker. Keep ≥ ActiveRecord pool size.
RAILS_MAX_THREADS=3

# Log verbosity: debug | info | warn | error | fatal
# RAILS_LOG_LEVEL=debug

# ── Production secrets ───────────────────────────────────────
# Required in production to decrypt config/credentials.yml.enc.
# In Kamal deployments this is sourced from .kamal/secrets.
# DO NOT set this in .env on a production server – use the secrets file.
# RAILS_MASTER_KEY=<contents of config/master.key>

# Explicit JWT signing key (optional – falls back to secret_key_base).
# Set this in production/staging so the key can be rotated independently
# of the Rails master key without invalidating all existing tokens.
# DEVISE_JWT_SECRET_KEY=<random 64-char hex string>

# ── Puma / concurrency ───────────────────────────────────────
# Number of Puma worker processes (multi-process mode). Default: 1.
# Increase only when running on a server with multiple CPU cores.
# WEB_CONCURRENCY=2

# Run Solid Queue inside the Puma process (set to true for single-server setups).
# SOLID_QUEUE_IN_PUMA=true

# Number of Solid Queue worker threads. Default: 1.
# JOB_CONCURRENCY=3

# ── Database ─────────────────────────────────────────────────
# Override the database host (e.g. for a separate DB container).
# Not needed when using the default SQLite on the same host.
# DB_HOST=127.0.0.1

# ── Mailer ───────────────────────────────────────────────────
# From-address shown in outbound Devise emails.
# Update config/initializers/devise.rb → config.mailer_sender to match.
# MAILER_SENDER=noreply@your-domain.example.com

# SMTP settings (only needed if Action Mailer is configured for real delivery)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_DOMAIN=your-domain.example.com

# ── Admin seed ───────────────────────────────────────────────
# Used by db/seeds.rb to create the initial admin account.
# Falls back to Rails.application.credentials.admin_email / admin_password.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme_in_production

